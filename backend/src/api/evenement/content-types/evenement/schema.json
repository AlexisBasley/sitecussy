{
  "kind": "collectionType",
  "collectionName": "evenements",
  "info": {
    "singularName": "evenement",
    "pluralName": "evenements",
    "displayName": "Événement",
    "description": "Événement de l'association (rando organisée, manifestation, AG, etc.)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titre",
      "required": true
    },
    "date_debut": {
      "type": "datetime",
      "required": true
    },
    "date_fin": {
      "type": "datetime"
    },
    "contenu": {
      "type": "richtext",
      "required": true
    },
    "image_couverture": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "flyer": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images", "files"]
    },
    "lieu": {
      "type": "string"
    },
    "balade": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::balade.balade"
    }
  }
}
