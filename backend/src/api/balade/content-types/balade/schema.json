{
  "kind": "collectionType",
  "collectionName": "balades",
  "info": {
    "singularName": "balade",
    "pluralName": "balades",
    "displayName": "Balade",
    "description": "Itinéraire VTT composé de un ou plusieurs chemins"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titre",
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "difficulte": {
      "type": "enumeration",
      "enum": ["famille", "intermediaire", "expert"],
      "required": true
    },
    "duree_estimee": {
      "type": "string",
      "required": true
    },
    "point_depart": {
      "type": "string",
      "required": true
    },
    "conseils": {
      "type": "text"
    },
    "photo_mise_en_avant": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "chemins": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::chemin.chemin",
      "inversedBy": "balades"
    }
  }
}
