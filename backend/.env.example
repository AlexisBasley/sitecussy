# =============================================================
# DEV LOCAL — sqlite, pas de Cloudinary, secrets fictifs
# =============================================================

# Server
HOST=0.0.0.0
PORT=1337
APP_KEYS=clef1,clef2,clef3,clef4
API_TOKEN_SALT=remplacer-en-prod
ADMIN_JWT_SECRET=remplacer-en-prod
TRANSFER_TOKEN_SALT=remplacer-en-prod
JWT_SECRET=remplacer-en-prod

# Database — sqlite par défaut en dev
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# CORS (frontend Nuxt local)
FRONTEND_URL=http://localhost:3000

# Cloudinary (vide = stockage local en dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

